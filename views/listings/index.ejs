<% layout("./layouts/boilerplate.ejs")%>
<body>
    <style>
        /* ── Filter Bar ─────────────────────────────── */
        #filters {
            margin-top: 1rem;
            display: flex;
            flex-wrap: nowrap;
            align-items: center;
            overflow-x: auto;
            -webkit-overflow-scrolling: touch;
            scrollbar-width: none;
            gap: 1.5rem;
            padding-bottom: 0.5rem;
        }
        #filters::-webkit-scrollbar { display: none; }

        .filter {
            text-align: center;
            flex-shrink: 0;
            opacity: 0.6;
            cursor: pointer;
            padding: 0.4rem 0.2rem;
            border-bottom: 2.5px solid transparent;
            transition: opacity 0.2s, border-color 0.2s;
            text-decoration: none;
            color: inherit;
        }
        .filter:hover { opacity: 1; color: inherit; }
        .filter.active {
            opacity: 1;
            border-bottom-color: #222;
        }
        .filter i { font-size: 1.2rem; display: block; margin-bottom: 0.2rem; }
        .filter p { font-size: 0.75rem; margin: 0; white-space: nowrap; }

        /* ── Tax Toggle ─────────────────────────────── */
        .tax-toggle {
            border: 1px solid #ddd;
            border-radius: 1rem;
            height: 3.2rem;
            padding: 0 1rem;
            margin-left: auto;
            flex-shrink: 0;
            display: flex;
            align-items: center;
        }
        .tax-info { display: none; }

        /* ── Cards ──────────────────────────────────── */
        .listing-card { border: none !important; margin-bottom: 2rem; }
        .card-img-top {
            border-radius: 1rem !important;
            width: 100% !important;
            object-fit: cover !important;
            aspect-ratio: 4/3;
        }
        .listing-link { text-decoration: none !important; }

        /* ── Empty state ─────────────────────────────── */
        .empty-state {
            text-align: center;
            padding: 4rem 1rem;
            color: #888;
        }
        .empty-state i { font-size: 3rem; margin-bottom: 1rem; }

        /* ── Responsive ─────────────────────────────── */
        @media (max-width: 576px) {
            .tax-toggle { display: none; }
        }
    </style>

    <div id="filters">
        <a href="/listings" class="filter <%= !activeCategory ? 'active' : '' %>" title="All">
            <i class="fa-solid fa-globe"></i>
            <p>All</p>
        </a>
        <a href="/listings?category=trending" class="filter <%= activeCategory === 'trending' ? 'active' : '' %>">
            <i class="fa-solid fa-fire"></i>
            <p>Trending</p>
        </a>
        <a href="/listings?category=rooms" class="filter <%= activeCategory === 'rooms' ? 'active' : '' %>">
            <i class="fa-solid fa-bed"></i>
            <p>Rooms</p>
        </a>
        <a href="/listings?category=iconic-cities" class="filter <%= activeCategory === 'iconic-cities' ? 'active' : '' %>">
            <i class="fa-solid fa-mountain-city"></i>
            <p>Iconic Cities</p>
        </a>
        <a href="/listings?category=mountains" class="filter <%= activeCategory === 'mountains' ? 'active' : '' %>">
            <i class="fa-solid fa-mountain"></i>
            <p>Mountains</p>
        </a>
        <a href="/listings?category=castles" class="filter <%= activeCategory === 'castles' ? 'active' : '' %>">
            <i class="fa-brands fa-fort-awesome"></i>
            <p>Castles</p>
        </a>
        <a href="/listings?category=amazing-pools" class="filter <%= activeCategory === 'amazing-pools' ? 'active' : '' %>">
            <i class="fa-solid fa-person-swimming"></i>
            <p>Amazing Pools</p>
        </a>
        <a href="/listings?category=camping" class="filter <%= activeCategory === 'camping' ? 'active' : '' %>">
            <i class="fa-solid fa-campground"></i>
            <p>Camping</p>
        </a>
        <a href="/listings?category=farms" class="filter <%= activeCategory === 'farms' ? 'active' : '' %>">
            <i class="fa-solid fa-cow"></i>
            <p>Farms</p>
        </a>
        <a href="/listings?category=arctic" class="filter <%= activeCategory === 'arctic' ? 'active' : '' %>">
            <i class="fa-regular fa-snowflake"></i>
            <p>Arctic</p>
        </a>
        <a href="/listings?category=domes" class="filter <%= activeCategory === 'domes' ? 'active' : '' %>">
            <i class="fa-solid fa-igloo"></i>
            <p>Domes</p>
        </a>
        <a href="/listings?category=boats" class="filter <%= activeCategory === 'boats' ? 'active' : '' %>">
            <i class="fa-solid fa-sailboat"></i>
            <p>Boats</p>
        </a>

        <div class="tax-toggle">
            <div class="form-check-reverse form-switch">
                <input class="form-check-input" type="checkbox" role="switch" id="flexSwitchCheckDefault">
                <label class="form-check-label" for="flexSwitchCheckDefault">Show taxes</label>
            </div>
        </div>
    </div>

    <% if (allListings.length === 0) { %>
        <div class="empty-state">
            <i class="fa-solid fa-house-circle-xmark"></i>
            <h4>No listings in this category yet</h4>
            <p>Be the first to <a href="/listings/new">add a listing</a> here!</p>
        </div>
    <% } else { %>
    <div class="row row-cols-xl-4 row-cols-lg-3 row-cols-md-2 row-cols-sm-2 row-cols-1 mt-3 g-3">
        <% for(let listing of allListings) { %>
        <div class="col">
        <a href="/listings/<%= listing._id %>" class="listing-link">
            <div class="card listing-card">
                <img src="<%= listing.image.url %>" class="card-img-top" alt="Listing image">
                <div class="card-body pt-2">
                    <p class="card-text mb-0">
                        <b><%= listing.title %></b>
                    </p>
                    <p class="card-text text-muted small mb-0"><%= listing.location %>, <%= listing.country %></p>
                    <p class="card-text">
                        <b>&#8377;<%= Number(listing.price).toLocaleString("en-IN") %></b> /night
                        <i class="tax-info">&nbsp;+18% GST</i>
                    </p>
                </div>
            </div>
        </a>
        </div>
        <% } %>
    </div>
    <% } %>

</body>
<!-- DEPLOYMENT_VERSION: 1.3-CATEGORIES -->

<script>
    let taxSwitch = document.querySelector("#flexSwitchCheckDefault");
    if (taxSwitch) {
        taxSwitch.addEventListener("click", () => {
            let taxItems = document.getElementsByClassName("tax-info");
            for (let info of taxItems) {
                info.style.display = info.style.display !== "inline" ? "inline" : "none";
            }
        });
    }
</script>
